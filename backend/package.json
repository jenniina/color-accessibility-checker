  "type": "module",
  "version": "0.0.0",
  "scripts": {
    "dev": "nodemon --watch src --ext ts,tsx --exec \"tsx src/server.ts\"",
    "dev:once": "tsx src/server.ts",
    "typecheck:watch": "tsc -w -p tsconfig.json",
    "start": "node --experimental-specifier-resolution=node dist/server.js",
    "build": "tsc -p tsconfig.json",
    "start:prod": "node --experimental-specifier-resolution=node dist/server.js"
  },
  "dependencies": {
    "@types/mongoose": "^5.11.96",
    "bcrypt": "^5.1.1",
    "bcryptjs": "^3.0.3",
    "compression": "^1.7.4",
    "cors": "^2.8.6",
    "dotenv": "^16.6.1",
    "express": "^4.19.2",
    "express-validator": "^7.3.1",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.9.5",
    "nodemailer": "^8.0.0",
    "sanitize-html": "^2.17.0",
    "sirv": "^2.0.4"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.2",
    "@types/compression": "^1.8.1",
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.25",
    "@types/express-serve-static-core": "^5.1.1",
    "@types/jsonwebtoken": "9.0.10",
    "@types/node": "^20.19.32",
    "@types/nodemailer": "^7.0.9",
    "@types/sanitize-html": "^2.16.0",
    "concurrently": "^9.2.1",
    "nodemon": "^3.1.11",
    "tsx": "^4.19.2",
    "typescript": "^5.6.2",
    "vite": "^6.4.1"
